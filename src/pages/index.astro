  ---
  import { getCollection } from 'astro:content';
  import BaseLayout from '../layouts/BaseLayout.astro';
  import Card from '@/components/astro/Card.astro';
  import CardHeader from '@/components/astro/CardHeader.astro';
  import CardTitle from '@/components/astro/CardTitle.astro';
  import CardDescription from '@/components/astro/CardDescription.astro';
  import CardContent from '@/components/astro/CardContent.astro';
  import CardFooter from '@/components/astro/CardFooter.astro';
  import Badge from '@/components/astro/Badge.astro';
  import Button from '@/components/astro/Button.astro';

  // Get all blog posts
  const allPosts = await getCollection('blog', ({ data }) => !data.draft);

  // Filter for root posts (no parent)
  const rootPosts = allPosts.filter(post => !post.data.parent);

  // Sort by date (newest first)
  const sortedRootPosts = rootPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

  // Count children for each root post
  const postChildrenCount = new Map<string, number>();
  for (const post of rootPosts) {
    const children = allPosts.filter(p => p.data.parent === post.id);
    postChildrenCount.set(post.id, children.length);
  }
  ---

  <BaseLayout>
    <div class="mx-auto max-w-4xl">
      <div class="mb-12 text-center">
        <h1 class="mb-4 text-4xl font-bold tracking-tight sm:text-5xl">
          Build It Yourself
        </h1>
        <p class="text-lg text-muted-foreground">
          Deep dives into complex UI/UX techniques. Because understanding beats copying.
        </p>
      </div>

      <div class="grid gap-8">
        {sortedRootPosts.map(post => {
          const childCount = postChildrenCount.get(post.id) || 0;
          return (
            <Card class="transition-all duration-200 hover:shadow-md hover:border-border/80 hover:-translate-y-0.5">
              <CardHeader class="pb-4">
                <div class="flex items-start justify-between gap-4">
                  <div class="flex-1">
                    <CardTitle class="mb-3 text-2xl font-bold leading-tight">
                      <a href={`/blog/${post.id}`} class="hover:text-primary transition-colors">
                        {post.data.title}
                      </a>
                    </CardTitle>
                    {childCount > 0 && (
                      <p class="text-xs font-medium text-muted-foreground mb-3 inline-block">
                        {childCount} sub-topic{childCount !== 1 ? 's' : ''}
                      </p>
                    )}
                    <CardDescription class="text-base leading-relaxed">{post.data.description}</CardDescription>
                  </div>
                </div>
              </CardHeader>
              <CardContent class="py-3">
                <div class="flex flex-wrap gap-2">
                  {post.data.tags?.map(tag => (
                    <Badge variant="secondary">{tag}</Badge>
                  ))}
                </div>
              </CardContent>
              <CardFooter class="justify-between border-t pt-5">
                <p class="text-xs font-medium text-muted-foreground">
                  {post.data.date.toLocaleDateString('en-US', { 
                    year: 'numeric', 
                    month: 'long', 
                    day: 'numeric' 
                  })}
                </p>
                <Button variant="ghost" href={`/blog/${post.id}`} class="text-sm">
                  Read →
                </Button>
              </CardFooter>
            </Card>
          );
        })}
      </div>
    </div>
  </BaseLayout>
