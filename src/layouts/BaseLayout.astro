---
import '../styles/globals.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'Build It Yourself', description = 'A dev blog about understanding complex UI/UX from first principles' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-background font-sans antialiased">
    <nav class="sticky top-0 z-50 w-full border-b bg-background/95 backdrop-blur supports-[backdrop-filter]:bg-background/60">
      <div class="container mx-auto flex h-14 max-w-screen-2xl items-center px-4">
        <div class="flex flex-1 items-center justify-between">
          <a href="/" class="text-xl font-bold">Build It Yourself</a>
          <a href="/" class="text-sm font-medium hover:text-primary transition-colors">Home</a>
        </div>
      </div>
    </nav>
    <main class="container mx-auto max-w-screen-2xl px-4 py-8">
      <slot />
    </main>
  </body>
</html>
